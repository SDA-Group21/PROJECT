@startuml

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()

title Apache Log4j2 - Integrated Runtime Architecture

Person(app, "Java Application", "Application using Log4j2 logging")

System_Ext(slf4jApi, "SLF4J API")
System_Ext(julApi, "java.util.logging")

System_Ext(fileSystem, "File System")
System_Ext(console, "Console")
System_Ext(remoteSystems, "Remote Logging Systems")


System_Boundary(api, "log4j-api") {

    Component(logManager, "LogManager", "Java", "Entry point used to retrieve loggers")

    Component(logger, "Logger", "Java", "Main logging interface used by applications")

    Component(extendedLogger, "ExtendedLogger", "Java", "Extended internal logging abstraction")

    Component(message, "Message", "Java", "Represents structured log messages")

    Component(level, "Level", "Java", "Represents logging severity levels")

    Component(marker, "Marker", "Java", "Adds metadata for filtering and categorization")

    Component(threadContext, "ThreadContext", "Java", "Stores contextual thread-related logging data")
}


System_Boundary(core, "log4j-core") {

    Component(loggerContext, "LoggerContext", "Java", "Maintains runtime logging state and active configurations")

    Component(configuration, "Configuration", "Java", "Stores logger rules, appenders, filters, and layouts")

    Component(logEvent, "LogEvent", "Java", "Represents a logging event generated by the application")

    Component(loggerConfig, "LoggerConfig", "Java", "Central orchestration component responsible for processing log events")

    Component(filter, "Filter", "Java", "Determines whether log events should be accepted or rejected")

    Component(asyncLogger, "AsyncLogger", "LMAX Disruptor", "Processes logging events asynchronously")

    Component(appenderControl, "AppenderControl", "Java", "Coordinates dispatching events to appenders")

    Component(appender, "Appender", "Java", "Writes log events to output destinations")

    Component(layout, "Layout", "Java", "Formats log events into output messages")

    Component(pluginManager, "PluginManager", "Java", "Discovers and loads extensible logging components")
}


System_Boundary(slf4jBridge, "log4j-slf4j2-impl") {

    Component(slf4jAdapter, "SLF4J Adapter", "Java", "Routes SLF4J API calls into Log4j2")
}

System_Boundary(julBridge, "log4j-jul") {

    Component(julAdapter, "JUL Adapter", "Java", "Redirects java.util.logging events into Log4j2")
}


Rel(app, logManager, "Retrieves logger")

Rel(logManager, logger, "Provides")

Rel(logger, extendedLogger, "Delegates advanced operations")

Rel(logger, message, "Creates messages")

Rel(logger, level, "Uses")

Rel(logger, marker, "Uses")

Rel(logger, threadContext, "Reads context")

Rel(logger, logEvent, "Creates logging event")


Rel(extendedLogger, loggerConfig, "Delegates processing")

Rel(loggerContext, configuration, "Uses active configuration")

Rel(configuration, loggerConfig, "Provides logger rules")

Rel(logEvent, loggerConfig, "Processed by")


Rel(loggerConfig, filter, "Applies filters")

Rel(loggerConfig, asyncLogger, "Delegates async processing")

Rel(asyncLogger, appenderControl, "Dispatches async events")

Rel(loggerConfig, appenderControl, "Delegates events")

Rel(appenderControl, appender, "Invokes")

Rel(appender, layout, "Formats messages using")


Rel(pluginManager, appender, "Loads plugins")

Rel(pluginManager, layout, "Loads plugins")

Rel(pluginManager, filter, "Loads plugins")


Rel(slf4jApi, slf4jAdapter, "Uses")

Rel(slf4jAdapter, logger, "Forwards log events")

Rel(julApi, julAdapter, "Uses")

Rel(julAdapter, logger, "Redirects log events")


Rel(appender, fileSystem, "Writes log files")

Rel(appender, console, "Prints logs")

Rel(appender, remoteSystems, "Sends remote logs")


' API on top
Lay_D(logManager, logger)

Lay_L(message, logger)
Lay_R(level, logger)

Lay_L(marker, extendedLogger)
Lay_R(threadContext, extendedLogger)

Lay_D(extendedLogger, logger)

' Core centered under API
Lay_D(logEvent, extendedLogger)

Lay_D(loggerConfig, logEvent)

Lay_L(filter, loggerConfig)
Lay_R(asyncLogger, loggerConfig)

Lay_D(appenderControl, loggerConfig)

Lay_D(appender, appenderControl)

Lay_D(layout, appender)

' Config side
Lay_L(configuration, loggerConfig)
Lay_U(loggerContext, configuration)

' Plugin side
Lay_R(pluginManager, appender)

' Bridges
Lay_R(slf4jAdapter, logger)
Lay_R(julAdapter, slf4jAdapter)

@enduml